{
  "expo": {
    "name": "UniSync",
    "slug": "unisync",
    "owner": "mahesh06",
    "scheme": "unisync",
    "version": "1.0.10",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "ios": {
      "supportsTablet": true,
      "buildNumber": "1.0.10"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.mahesh0603.unisync",
      "versionCode": 10,
      "permissions": [
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      "expo-web-browser",
      "expo-notifications",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow UniSync to access photos so you can upload lost or found item images.",
          "cameraPermission": "Allow UniSync to use your camera to scan and report campus items."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow UniSync to access your location to auto-fill where an item was found."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "ad810152-606c-40b1-ba87-292f2fc33d16"
      }
    }
  }
}
