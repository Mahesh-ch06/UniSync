{
  "expo": {
    "name": "UniSync",
    "slug": "unisync",
    "owner": "mahesh0603",
    "scheme": "unisync",
    "version": "1.0.6",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "buildNumber": "1.0.6"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.mahesh0603.MobileApp",
      "versionCode": 6,
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow CampusFind to access photos so you can upload lost or found item images.",
          "cameraPermission": "Allow CampusFind to use your camera to scan and report campus items."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "aa032913-0356-40a8-89f6-ee6ccc730f8f"
      }
    }
  }
}
