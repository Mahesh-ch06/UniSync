{
  "name": "mobileapp",
  "version": "1.0.7",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "start:lan": "expo start --lan",
    "start:tunnel": "expo start --tunnel",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build:apk": "eas build -p android --profile apk",
    "build:aab": "eas build -p android --profile production",
    "backend:start": "npm --prefix backend run start",
    "backend:dev": "npm --prefix backend run dev",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@clerk/clerk-expo": "^2.19.31",
    "@expo-google-fonts/inter": "^0.4.2",
    "@expo-google-fonts/manrope": "^0.4.2",
    "@expo/vector-icons": "^15.1.1",
    "@react-native-async-storage/async-storage": "^3.0.2",
    "@react-navigation/bottom-tabs": "^7.15.9",
    "@react-navigation/native": "^7.2.2",
    "@supabase/supabase-js": "^2.101.1",
    "expo": "~54.0.33",
    "expo-auth-session": "~7.0.10",
    "expo-constants": "~18.0.13",
    "expo-device": "~8.0.10",
    "expo-font": "~14.0.11",
    "expo-image-picker": "~17.0.10",
    "expo-linear-gradient": "~15.0.8",
    "expo-location": "~19.0.8",
    "expo-network": "~8.0.8",
    "expo-notifications": "~0.32.16",
    "expo-secure-store": "~15.0.7",
    "expo-status-bar": "~3.0.9",
    "expo-web-browser": "~15.0.10",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-maps": "1.20.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-url-polyfill": "^3.0.0"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "babel-preset-expo": "^54.0.10",
    "patch-package": "^8.0.1",
    "typescript": "~5.9.2"
  },
  "expo": {
    "install": {
      "exclude": [
        "react",
        "react-dom"
      ]
    }
  },
  "private": true
}
